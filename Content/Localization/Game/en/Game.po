#. Key:	D620319E40FAF04046146894C48082E1
#. SourceLocation:	/Game/DT_Trait.DT_Trait.ATK_Crit.Description
#: /Game/DT_Trait.DT_Trait.ATK_Crit.Description
msgctxt ",D620319E40FAF04046146894C48082E1"
msgid "(조건: 화력 강화 2Lv)<br>치명타 확률 및 피해량 배율 증가"
msgstr "(Requires: Firepower Lv.2)<br>Increases Critical Hit Rate and Critical Damage Multiplier"

#. Key:	1BD4123E40BE28642D370B995109889E
#. SourceLocation:	/Game/DT_Trait.DT_Trait.ATK_Damage.Description
#: /Game/DT_Trait.DT_Trait.ATK_Damage.Description
msgctxt ",1BD4123E40BE28642D370B995109889E"
msgid "기본 무기 피해량 증가<br>(레벨당 5%)"
msgstr "Increases base weapon damage<br>(+5% per level)"

#. Key:	EE37293F4AA5E9B25DC48B9AF48F4300
#. SourceLocation:	/Game/DT_Trait.DT_Trait.ATK_Mag.Description
#: /Game/DT_Trait.DT_Trait.ATK_Mag.Description
msgctxt ",EE37293F4AA5E9B25DC48B9AF48F4300"
msgid "(조건: 전술 장전 3Lv)<br>기본 무기의 탄창 용량 증가"
msgstr "(Requires: Tactical Reload Lv.3)<br>Increases base weapon magazine capacity"

#. Key:	59246FC14BCE1B120F7006805CE13A5E
#. SourceLocation:	/Game/DT_Trait.DT_Trait.ATK_Reload.Description
#: /Game/DT_Trait.DT_Trait.ATK_Reload.Description
msgctxt ",59246FC14BCE1B120F7006805CE13A5E"
msgid "(조건: 화력 강화 1Lv)<br>재장전 속도 감소"
msgstr "(Requires: Firepower Lv.1)<br>Decreases reload time"

#. Key:	48D27E4444380FE01FA2C4AAE39A7203
#. SourceLocation:	/Game/DT_Trait.DT_Trait.ATK_Suppress.Description
#: /Game/DT_Trait.DT_Trait.ATK_Suppress.Description
msgctxt ",48D27E4444380FE01FA2C4AAE39A7203"
msgid "(조건: 급소 조준 3Lv)<br>피격당한 적의 이동 속도를 잠깐 늦추거나<br>미세한 경직을 발생시킴"
msgstr "(Requires: Precision Aim Lv.3)<br>Briefly slows down or inflicts minor hitstun<br>on enemies hit"

#. Key:	A01FC5444E9C072562215CB2416B3467
#. SourceLocation:	/Game/DT_Trait.DT_Trait.SUR_Armor.Description
#: /Game/DT_Trait.DT_Trait.SUR_Armor.Description
msgctxt ",A01FC5444E9C072562215CB2416B3467"
msgid "(조건: 체력 단련 2Lv)<br>피격 시 받는 피해량 퍼센트 단위로 감소"
msgstr "(Requires: Fitness Lv.2)<br>Reduces incoming damage by a percentage"

#. Key:	4991BF344E9C8FCE4F7D849FDCBB4C48
#. SourceLocation:	/Game/DT_Trait.DT_Trait.SUR_Heal.Description
#: /Game/DT_Trait.DT_Trait.SUR_Heal.Description
msgctxt ",4991BF344E9C8FCE4F7D849FDCBB4C48"
msgid "(조건: 방호복 강화 3Lv)<br>레벨업 시 잃은 체력의 일부 자동 회복"
msgstr "(Requires: Exo-Suit Upgrade Lv.3)<br>Automatically restores a portion of missing HP upon leveling up"

#. Key:	35F1F6944843C13D386EC1B7A0CC0B86
#. SourceLocation:	/Game/DT_Trait.DT_Trait.SUR_Health.Description
#: /Game/DT_Trait.DT_Trait.SUR_Health.Description
msgctxt ",35F1F6944843C13D386EC1B7A0CC0B86"
msgid "최대 체력 증가<br>(레벨당 10%)"
msgstr "Increases maximum HP<br>(+10% per level)"

#. Key:	A4CCC1054749805A6D9F2EB0F1B3B1E5
#. SourceLocation:	/Game/DT_Trait.DT_Trait.SUR_Revive.Description
#: /Game/DT_Trait.DT_Trait.SUR_Revive.Description
msgctxt ",A4CCC1054749805A6D9F2EB0F1B3B1E5"
msgid "(조건: 전술 기동 3Lv)<br>치명적인 피해를 입었을 때<br>체력 1로 생존 후 짧은 무적 제공<br>(레벨이 오를수록 발동 쿨타임 감소)"
msgstr "(Requires: Tactical Maneuvers Lv.3)<br>Survive fatal damage with 1 HP and gain brief invincibility<br>(Cooldown decreases per level)"

#. Key:	4F10CC1F4A81881BEB50B4862E042F43
#. SourceLocation:	/Game/DT_Trait.DT_Trait.SUR_Speed.Description
#: /Game/DT_Trait.DT_Trait.SUR_Speed.Description
msgctxt ",4F10CC1F4A81881BEB50B4862E042F43"
msgid "(조건: 체력 단련 1Lv)<br>기본 이동 속도 증가 및 대시 쿨타임 감소"
msgstr "(Requires: Fitness Lv.1)<br>Increases base movement speed and reduces dash cooldown"

#. Key:	F377A23F4AC65E70E8485BA430AEF262
#. SourceLocation:	/Game/DT_Trait.DT_Trait.UTL_Discount.Description
#: /Game/DT_Trait.DT_Trait.UTL_Discount.Description
msgctxt ",F377A23F4AC65E70E8485BA430AEF262"
msgid "(조건: 보급품 탐색 3Lv)<br>특성 업그레이드에서 구매하는 아이템<br>가격 영구 할인"
msgstr "(Requires: Scavenge Supplies Lv.3)<br>Permanently discounts the price of items<br>in Trait Upgrades"

#. Key:	552C96E440D2E8776EFE069446A84AB1
#. SourceLocation:	/Game/DT_Trait.DT_Trait.UTL_Drop.Description
#: /Game/DT_Trait.DT_Trait.UTL_Drop.Description
msgctxt ",552C96E440D2E8776EFE069446A84AB1"
msgid "적 처치 시 획득하는 영구 업그레이드 재화 드랍률 증가"
msgstr "Increases drop rate of permanent upgrade currency from defeated enemies"

#. Key:	B29599B04220E0A418EDEDB26B457027
#. SourceLocation:	/Game/DT_Trait.DT_Trait.UTL_Rarity.Description
#: /Game/DT_Trait.DT_Trait.UTL_Rarity.Description
msgctxt ",B29599B04220E0A418EDEDB26B457027"
msgid "(조건: 자원 채굴 1Lv)<br>인게임에서 특수 무기가 등장할 확률 증가"
msgstr "(Requires: Resource Mining Lv.1)<br>Increases the spawn rate of special weapons in-game"

#. Key:	399AFB94400490E4CA39399BF19A9794
#. SourceLocation:	/Game/DT_Trait.DT_Trait.UTL_Reroll.Description
#: /Game/DT_Trait.DT_Trait.UTL_Reroll.Description
msgctxt ",399AFB94400490E4CA39399BF19A9794"
msgid "(조건: 시작 보급 3Lv)<br>인게임 레벨업 시 등장하는<br>능력치 선택지 개수 증가 및 새로고침 기능 해금"
msgstr "(Requires: Starting Supplies Lv.3)<br>Increases the number of stat options upon level-up<br>and unlocks the Reroll feature"

#. Key:	D89159784DE7EEB4C23960B3B9474924
#. SourceLocation:	/Game/DT_Trait.DT_Trait.UTL_StartCash.Description
#: /Game/DT_Trait.DT_Trait.UTL_StartCash.Description
msgctxt ",D89159784DE7EEB4C23960B3B9474924"
msgid "(조건: 자원 채굴 2Lv)<br>매 회차 시작 시 기본 레벨 증가"
msgstr "(Requires: Resource Mining Lv.2)<br>Increases starting base level for each run"

